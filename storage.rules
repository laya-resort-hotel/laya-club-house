rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function hasUserDoc() {
      return signedIn() &&
        exists(/databases/(default)/documents/users/$(myUid()));
    }

    function userRole() {
      return hasUserDoc()
        ? get(/databases/(default)/documents/users/$(myUid())).data.role
        : null;
    }

    function isAdminLike() {
      return userRole() in ['super_admin', 'admin'];
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
    }

    match /profiles/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && (userId == myUid() || isAdminLike()) && isImageUpload();
      allow delete: if signedIn() && (userId == myUid() || isAdminLike());
    }

    match /rewards/{rewardId}/{fileName} {
      allow read: if signedIn();
      allow write: if isAdminLike() && isImageUpload();
      allow delete: if isAdminLike();
    }

    match /content_banners/{bannerId}/{fileName} {
      allow read: if signedIn();
      allow write: if isAdminLike() && isImageUpload();
      allow delete: if isAdminLike();
    }

    match /cards/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdminLike() && isImageUpload();
      allow delete: if isAdminLike();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
